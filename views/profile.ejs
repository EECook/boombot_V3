<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <link rel="stylesheet" href="/css/landing.css" />
  <link rel="stylesheet" href="/css/feed.css" />
  <link rel="stylesheet" href="/css/profile.css" />
</head>
<body class="theater">
  <canvas id="theater-bg" aria-hidden="true"></canvas>
  <canvas id="mouse-trail" aria-hidden="true"></canvas>
  <div class="curtain curtain-left" aria-hidden="true"></div>
  <div class="curtain curtain-right" aria-hidden="true"></div>
  <div class="curtain-valance" aria-hidden="true"></div>

  <%- include('partials/nav') %>

  <main class="hub-layout">
    <aside class="profile-card">
      <img src="<%= profileUser.avatarUrl %>" alt="" class="profile-avatar" />
      <h1 class="profile-name"><%= profileUser.username %></h1>
      <% if (profile.pronouns) { %><p class="profile-pronouns"><%= profile.pronouns %></p><% } %>

      <% if (profile.is_live && profile.live_url && !isOwnProfile) { %>
        <a href="<%= profile.live_url %>" target="_blank" rel="noopener noreferrer" class="profile-live-badge">
          <span class="live-dot" aria-hidden="true"></span> LIVE NOW &rarr;
        </a>
      <% } %>

      <dl class="profile-facts">
        <% if (profile.age) { %><div><dt>Age</dt><dd><%= profile.age %></dd></div><% } %>
        <% if (profile.birthday) { %><div><dt>Birthday</dt><dd><%= new Date(profile.birthday).toLocaleDateString(undefined, { month: 'long', day: 'numeric' }) %></dd></div><% } %>
        <% if (profile.timezone) { %><div><dt>Timezone</dt><dd><%= profile.timezone %></dd></div><% } %>
      </dl>

      <% if (profile.bio) { %><p class="profile-bio"><%= profile.bio %></p><% } %>

      <% if (links.length > 0) { %>
        <ul class="profile-links">
          <% links.forEach(function(link) { %>
            <li><a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" style="border-color: <%= link.meta.color %>66; color: <%= link.meta.color %>;"><%= link.meta.icon %> <%= link.meta.label %></a></li>
          <% }); %>
        </ul>
      <% } %>

      <% if (isOwnProfile) { %>
        <div class="quick-live-toggle" id="quick-live-toggle" data-live="<%= profile.is_live ? 'true' : 'false' %>">
          <button type="button" id="quick-live-btn" class="live-toggle-btn <%= profile.is_live ? 'is-live' : '' %>">
            <span class="live-dot" aria-hidden="true"></span>
            <span id="quick-live-label"><%= profile.is_live ? 'End Stream' : 'Go Live' %></span>
          </button>
          <input
            type="url"
            id="quick-live-url"
            placeholder="https://twitch.tv/yourname"
            value="<%= profile.live_url || '' %>"
            style="<%= profile.is_live ? '' : 'display:none;' %>"
          />
        </div>
        <a href="/profile/edit" class="btn btn-ticket btn-small" style="margin-top: 0.8rem;">Edit Profile</a>
      <% } %>
    </aside>

    <section class="feed-panel">
      <h2 class="panel-title"><%= isOwnProfile ? 'Your Wall' : profileUser.username + "'s Wall" %></h2>

      <form class="composer" id="feed-composer">
        <textarea name="body" placeholder="<%= isOwnProfile ? 'Write on your own wall...' : 'Write something on ' + profileUser.username + '\'s wall...' %>" maxlength="2000" required></textarea>
        <input type="url" name="mediaUrl" class="composer-media-input" placeholder="Paste an image link (optional)" />
        <button type="submit" class="btn btn-ticket btn-small">Post</button>
      </form>

      <div class="post-list" id="feed-post-list">
        <% wallPosts.forEach(function(post) { %>
          <%- include('partials/post-card', { post: post, canInteract: true, viewerId: user.id, viewerIsAdmin: !!user.is_admin }) %>
        <% }); %>
        <% if (wallPosts.length === 0) { %>
          <p class="feed-empty">Nothing here yet &mdash; be the first to write something.</p>
        <% } %>
      </div>
    </section>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/theater-bg.js"></script>
  <script src="/js/mouse-trail.js"></script>
  <script>window.BOOMBOT_CONTEXT = { wallUserId: <%= profileUser.id %>, authenticated: true, userId: <%= user.id %>, isAdmin: <%= !!user.is_admin %> };
  window.BOOMBOT_PAGE = <%- JSON.stringify('Viewing ' + profileUser.username + "'s profile") %>;</script>
  <script src="/js/socket-client.js"></script>
  <script src="/js/presence.js"></script>
  <script src="/js/feed.js"></script>
  <script src="/js/profile-live-toggle.js"></script>
</body>
</html>
