<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <link rel="stylesheet" href="/css/landing.css" />
</head>
<body class="theater">
  <canvas id="theater-bg" aria-hidden="true"></canvas>
  <canvas id="mouse-trail" aria-hidden="true"></canvas>

  <div class="curtain curtain-left" aria-hidden="true"></div>
  <div class="curtain curtain-right" aria-hidden="true"></div>
  <div class="curtain-valance" aria-hidden="true"></div>

  <%- include('partials/nav') %>

  <div class="decor" aria-hidden="true">
    <svg class="decor-item" style="top: 18%; left: 8%; width: 54px; height: 54px; animation-duration: 19s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="2.4"/><circle cx="12" cy="6" r="1.4"/><circle cx="17" cy="9.5" r="1.4"/><circle cx="17" cy="14.5" r="1.4"/><circle cx="12" cy="18" r="1.4"/><circle cx="7" cy="14.5" r="1.4"/><circle cx="7" cy="9.5" r="1.4"/></svg>
    <svg class="decor-item teal" style="top: 62%; left: 12%; width: 40px; height: 40px; animation-duration: 15s; animation-delay: -4s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M4 8l1-4h14l1 4-2 12H6L4 8z"/><path d="M8 8v12M12 8v12M16 8v12"/></svg>
    <svg class="decor-item" style="top: 74%; right: 10%; width: 46px; height: 46px; animation-duration: 21s; animation-delay: -9s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 9a2 2 0 100 4 2 2 0 010 4h18a2 2 0 010-4 2 2 0 100-4 2 2 0 000-4H3a2 2 0 000 4z"/><path d="M9 5v3M9 11v2M9 16v3"/></svg>
    <svg class="decor-item teal" style="top: 30%; right: 14%; width: 34px; height: 34px; animation-duration: 17s; animation-delay: -2s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="2.4"/><circle cx="12" cy="6" r="1.4"/><circle cx="17" cy="9.5" r="1.4"/><circle cx="17" cy="14.5" r="1.4"/><circle cx="12" cy="18" r="1.4"/><circle cx="7" cy="14.5" r="1.4"/><circle cx="7" cy="9.5" r="1.4"/></svg>
    <svg class="decor-item" style="top: 46%; left: 5%; width: 30px; height: 30px; animation-duration: 13s; animation-delay: -6s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M4 8l1-4h14l1 4-2 12H6L4 8z"/><path d="M8 8v12M12 8v12M16 8v12"/></svg>
    <svg class="decor-item teal" style="top: 85%; left: 30%; width: 26px; height: 26px; animation-duration: 20s; animation-delay: -11s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 9a2 2 0 100 4 2 2 0 010 4h18a2 2 0 010-4 2 2 0 100-4 2 2 0 000-4H3a2 2 0 000 4z"/><path d="M9 5v3M9 11v2M9 16v3"/></svg>
  </div>

  <main class="lobby">
    <section class="marquee-wrap" id="marquee">
      <div class="marquee" id="marquee-card">
        <div class="marquee-canopy" aria-hidden="true"></div>
        <p class="marquee-eyebrow">Now Screening For Our Server</p>
        <h1 class="marquee-title">Family<br />Movie Night</h1>
        <p class="marquee-sub">Come for the movie. Stay for the after-chat arguing about the ending.</p>
      </div>
    </section>

    <section class="pitch">
      <a href="/signin" class="btn btn-ticket btn-large">
        <span class="ticket-clip" aria-hidden="true"></span>
        Step Inside
      </a>
    </section>

    <section class="filmstrip" aria-hidden="true">
      <div class="filmstrip-track"></div>
    </section>
  </main>

  <script src="/js/theater-bg.js"></script>
  <script src="/js/mouse-trail.js"></script>
  <script src="/js/marquee.js"></script>
  <script src="/js/marquee-tilt.js"></script>
</body>
</html>
