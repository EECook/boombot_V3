<% var canInteract = (typeof canInteract === 'undefined') ? true : canInteract; %>
<% var viewerId = (typeof viewerId === 'undefined') ? null : viewerId; %>
<% var viewerIsAdmin = (typeof viewerIsAdmin === 'undefined') ? false : viewerIsAdmin; %>
<% var canDelete = canInteract && (viewerId === post.author.id || viewerIsAdmin); %>
<article class="post-card" data-post-id="<%= post.id %>">
  <div class="post-perf" aria-hidden="true"></div>
  <div class="post-head">
    <img src="<%= post.author.avatarUrl %>" alt="" class="post-avatar" />
    <div>
      <a href="/profile/<%= post.author.discordId %>" class="post-author"><%= post.author.username %></a>
      <time class="post-time" data-iso="<%= post.createdAt %>"><%= new Date(post.createdAt).toLocaleString() %></time>
    </div>
    <% if (canDelete) { %>
      <button class="post-delete-btn" data-post-id="<%= post.id %>" aria-label="Delete post" title="Delete post">&times;</button>
    <% } %>
  </div>

  <p class="post-body"><%= post.body %></p>
  <% if (post.mediaUrl) { %>
    <img src="<%= post.mediaUrl %>" alt="" class="post-media" loading="lazy" />
  <% } %>

  <div class="post-actions">
    <div class="reaction-row" data-post-id="<%= post.id %>">
      <% post.reactions.forEach(function(r) { %>
        <button class="reaction-pill <%= r.viewerReacted ? 'active' : '' %>" data-post-id="<%= post.id %>" data-emoji="<%= r.emoji %>" <%= canInteract ? '' : 'disabled' %>>
          <span><%= r.emoji %></span><span class="reaction-count"><%= r.count %></span>
        </button>
      <% }); %>
      <% if (canInteract) { %>
        <button class="reaction-add-btn" data-post-id="<%= post.id %>" aria-label="Add reaction">+</button>
      <% } %>
    </div>
    <% if (canInteract) { %>
      <button class="comment-toggle-btn" data-post-id="<%= post.id %>">
        <%= post.commentCount %> comment<%= post.commentCount === 1 ? '' : 's' %>
      </button>
    <% } else { %>
      <a href="/signin" class="comment-toggle-btn">
        <%= post.commentCount %> comment<%= post.commentCount === 1 ? '' : 's' %>
      </a>
    <% } %>
  </div>

  <div class="post-comments <%= canInteract ? '' : 'open' %>">
    <div class="comment-list">
      <% post.comments.forEach(function(comment) { %>
        <div class="comment">
          <a href="/profile/<%= comment.author.discordId %>" class="comment-author"><%= comment.author.username %></a>
          <span class="comment-body"><%= comment.body %></span>
        </div>
      <% }); %>
    </div>
    <% if (canInteract) { %>
      <form class="comment-form" data-post-id="<%= post.id %>">
        <input type="text" name="body" placeholder="Write a comment&hellip;" maxlength="1000" required />
        <button type="submit" class="btn btn-ticket btn-small">Post</button>
      </form>
    <% } else if (post.comments.length === 0) { %>
      <a href="/signin" class="signin-prompt">Sign in to join the conversation</a>
    <% } %>
  </div>
</article>
