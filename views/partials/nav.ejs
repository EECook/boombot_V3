<nav class="site-nav">
  <a href="/" class="brand">
    <span class="brand-mark">🎞️</span>
    <span class="brand-text">Family Movie Night</span>
  </a>

  <div class="nav-links">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/hub" class="nav-link">The Hub</a>
    <% } %>
    <!-- Future primary sections (Schedule, Backlog, Quotes) go here -->
  </div>

  <div class="nav-actions">
    <div class="official-socials">
      <a href="https://x.com/FamMovieNight_" target="_blank" rel="noopener noreferrer" class="official-social-link" aria-label="Family Movie Night on X">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.9 2H22l-7.6 8.7L23.3 22h-7.1l-5.5-7.2L4.3 22H1.2l8.1-9.3L1 2h7.3l5 6.6L18.9 2zm-1.2 18h1.9L7.4 4H5.4l12.3 16z"/></svg>
      </a>
      <a href="https://www.youtube.com/@FamMovieNight" target="_blank" rel="noopener noreferrer" class="official-social-link" aria-label="Family Movie Night on YouTube">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
      </a>
    </div>
    <% if (typeof user !== 'undefined' && user) { %>
      <div class="user-menu" id="user-menu">
        <button type="button" class="user-menu-trigger" id="user-menu-trigger" aria-haspopup="true" aria-expanded="false">
          <img src="<%= user.avatarUrl %>" alt="" class="nav-avatar" />
          <span class="user-menu-name"><%= user.username %></span>
          <span class="user-menu-caret" aria-hidden="true">&#9662;</span>
        </button>
        <div class="user-menu-dropdown" id="user-menu-dropdown">
          <a href="/profile/<%= user.discord_id %>" class="user-menu-item">My Profile</a>
          <a href="/profile/edit" class="user-menu-item">Edit Profile</a>
          <div class="user-menu-divider" aria-hidden="true"></div>
          <form action="/auth/logout" method="POST" class="user-menu-form">
            <button type="submit" class="user-menu-item user-menu-item-danger">Sign out</button>
          </form>
        </div>
      </div>
    <% } else { %>
      <a href="/signin" class="btn btn-ticket btn-small">Sign In</a>
    <% } %>
  </div>
</nav>
<script src="/js/nav-dropdown.js" defer></script>
