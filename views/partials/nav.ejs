<nav class="site-nav">
  <a href="/" class="brand">
    <span class="brand-mark">🎞️</span>
    <span class="brand-text">Family Movie Night</span>
  </a>

  <div class="nav-links">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/hub" class="nav-link">The Hub</a>
    <% } %>
    <!-- Future primary sections (Schedule, Backlog, Quotes) go here -->
  </div>

  <div class="nav-actions">
    <% if (typeof user !== 'undefined' && user) { %>
      <div class="user-menu" id="user-menu">
        <button type="button" class="user-menu-trigger" id="user-menu-trigger" aria-haspopup="true" aria-expanded="false">
          <img src="<%= user.avatarUrl %>" alt="" class="nav-avatar" />
          <span class="user-menu-name"><%= user.username %></span>
          <span class="user-menu-caret" aria-hidden="true">&#9662;</span>
        </button>
        <div class="user-menu-dropdown" id="user-menu-dropdown">
          <a href="/profile/<%= user.discord_id %>" class="user-menu-item">My Profile</a>
          <a href="/profile/edit" class="user-menu-item">Edit Profile</a>
          <div class="user-menu-divider" aria-hidden="true"></div>
          <form action="/auth/logout" method="POST" class="user-menu-form">
            <button type="submit" class="user-menu-item user-menu-item-danger">Sign out</button>
          </form>
        </div>
      </div>
    <% } else { %>
      <a href="/signin" class="btn btn-ticket btn-small">Sign In</a>
    <% } %>
  </div>
</nav>
<script src="/js/nav-dropdown.js" defer></script>
