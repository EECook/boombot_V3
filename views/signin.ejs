<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <link rel="stylesheet" href="/css/signin.css" />
</head>
<body class="theater">
  <canvas id="theater-bg" aria-hidden="true"></canvas>
  <canvas id="mouse-trail" aria-hidden="true"></canvas>

  <div class="curtain curtain-left" aria-hidden="true"></div>
  <div class="curtain curtain-right" aria-hidden="true"></div>
  <div class="curtain-valance" aria-hidden="true"></div>

  <%- include('partials/nav') %>

  <main class="booth">
    <div class="ticket-card">
      <div class="ticket-perf" aria-hidden="true"></div>

      <p class="ticket-eyebrow">Admit One</p>
      <h1 class="ticket-title">Show Your Ticket</h1>
      <p class="ticket-sub">Only folks in the Discord get past the rope.</p>

      <% if (error) { %>
        <p class="ticket-error"><%= error %></p>
      <% } %>

      <a href="/auth/discord" class="btn btn-discord btn-large">
        <svg width="20" height="20" viewBox="0 0 127.14 96.36" fill="currentColor" aria-hidden="true">
          <path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/>
        </svg>
        Sign in with Discord
      </a>

      <div class="divider"><span>or use a code from Boombot</span></div>

      <form action="/auth/link-code" method="POST" class="code-form">
        <label for="code" class="code-label">Type <code>!link</code> in Discord, then enter the code it DMs you</label>
        <div class="code-row">
          <input
            type="text"
            id="code"
            name="code"
            maxlength="12"
            placeholder="XXXX-XXXX"
            autocomplete="one-time-code"
            required
          />
          <button type="submit" class="btn btn-ticket btn-small">Enter</button>
        </div>
      </form>
    </div>
  </main>

  <script src="/js/theater-bg.js"></script>
  <script src="/js/mouse-trail.js"></script>
</body>
</html>
