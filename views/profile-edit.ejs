<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <link rel="stylesheet" href="/css/landing.css" />
  <link rel="stylesheet" href="/css/signin.css" />
  <link rel="stylesheet" href="/css/profile.css" />
</head>
<body class="theater">
  <canvas id="theater-bg" aria-hidden="true"></canvas>
  <canvas id="mouse-trail" aria-hidden="true"></canvas>
  <div class="curtain curtain-left" aria-hidden="true"></div>
  <div class="curtain curtain-right" aria-hidden="true"></div>
  <div class="curtain-valance" aria-hidden="true"></div>

  <%- include('partials/nav') %>

  <main class="booth" style="min-height: auto; padding-bottom: 6vh;">
    <div class="ticket-card" style="width: min(560px, 100%);">
      <p class="ticket-eyebrow">Wardrobe &amp; Bio</p>
      <h1 class="ticket-title">Edit Your Profile</h1>

      <form action="/profile/edit" method="POST" class="edit-form">
        <label class="field-label">
          Custom photo URL <span class="field-hint">(leave blank to keep your Discord avatar)</span>
          <input type="url" name="customAvatarUrl" value="<%= profile.custom_avatar_url || '' %>" placeholder="https://..." />
        </label>

        <div class="field-row">
          <label class="field-label">
            Pronouns
            <select name="pronouns">
              <option value="">Prefer not to say</option>
              <% pronounOptions.forEach(function(p) { %>
                <option value="<%= p %>" <%= profile.pronouns === p ? 'selected' : '' %>><%= p %></option>
              <% }); %>
            </select>
          </label>

          <label class="field-label">
            Age
            <input type="number" name="age" min="1" max="120" value="<%= profile.age || '' %>" />
          </label>
        </div>

        <div class="field-row">
          <label class="field-label">
            Birthday
            <input type="date" name="birthday" value="<%= profile.birthday ? new Date(profile.birthday).toISOString().slice(0,10) : '' %>" />
          </label>

          <label class="field-label">
            Timezone
            <select name="timezone">
              <option value="">Prefer not to say</option>
              <% timezoneOptions.forEach(function(tz) { %>
                <option value="<%= tz %>" <%= profile.timezone === tz ? 'selected' : '' %>><%= tz %></option>
              <% }); %>
            </select>
          </label>
        </div>

        <label class="field-label">
          Bio
          <textarea name="bio" rows="4" maxlength="2000" placeholder="Tell everyone a little about yourself..."><%= profile.bio || '' %></textarea>
        </label>

        <div class="live-toggle-row" id="live-toggle-row" data-live="<%= profile.is_live ? 'true' : 'false' %>">
          <input type="hidden" name="isLive" id="isLive" value="<%= profile.is_live ? 'on' : '' %>" />
          <button type="button" id="live-toggle-btn" class="live-toggle-btn <%= profile.is_live ? 'is-live' : '' %>">
            <span class="live-dot" aria-hidden="true"></span>
            <span id="live-toggle-label"><%= profile.is_live ? 'End Stream' : 'Go Live' %></span>
          </button>
          <input
            type="url"
            name="liveUrl"
            id="liveUrl"
            placeholder="https://twitch.tv/yourname"
            value="<%= profile.live_url || '' %>"
            style="<%= profile.is_live ? '' : 'display:none;' %>"
          />
        </div>

        <div class="social-links-editor">
          <p class="field-label" style="margin-bottom: 0.6rem;">Social links</p>
          <div id="social-links-rows">
            <% (links.length ? links : [{platform: '', url: ''}]).forEach(function(link) { %>
              <div class="link-row">
                <select name="linkPlatform">
                  <% platforms.forEach(function(p) { %>
                    <option value="<%= p.id %>" <%= link.platform === p.id ? 'selected' : '' %>><%= p.icon %> <%= p.label %></option>
                  <% }); %>
                </select>
                <input type="url" name="linkUrl" placeholder="https://..." value="<%= link.url %>" maxlength="512" />
                <button type="button" class="link-remove-btn" aria-label="Remove">&times;</button>
              </div>
            <% }); %>
          </div>
          <button type="button" id="add-link-btn" class="btn btn-ghost btn-small">+ Add another link</button>
        </div>

        <div class="edit-actions">
          <a href="/profile/<%= discordId %>" class="btn btn-ghost btn-small" id="cancel-link">Cancel</a>
          <button type="submit" class="btn btn-ticket btn-large">Save Profile</button>
        </div>
      </form>
    </div>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/theater-bg.js"></script>
  <script src="/js/mouse-trail.js"></script>
  <script>window.BOOMBOT_PAGE = 'Editing their profile';</script>
  <script src="/js/socket-client.js"></script>
  <script src="/js/presence.js"></script>
  <script src="/js/profile-edit.js"></script>
</body>
</html>
